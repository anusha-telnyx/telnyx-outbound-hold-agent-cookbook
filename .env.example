# Required
TELNYX_API_KEY=
TELNYX_CONNECTION_ID=
TELNYX_FROM_NUMBER=
TELNYX_IVR_ASSISTANT_ID=
TELNYX_REPRESENTATIVE_ASSISTANT_ID=
PUBLIC_BASE_URL=

# Recommended for production webhook verification.
# Telnyx sends telnyx-timestamp and telnyx-signature-ed25519 headers.
TELNYX_PUBLIC_KEY=

# Optional behavior
TELNYX_API_BASE_URL=https://api.telnyx.com/v2
APP_HOST=0.0.0.0
APP_PORT=8000
START_TRANSCRIPTION_DURING_IVR=false
TRANSCRIPTION_ENGINE=Deepgram
TRANSCRIPTION_MODEL=deepgram/nova-3
TRANSCRIPTION_LANGUAGE=en
TRANSCRIPTION_TRACKS=both
HOLD_CONFIDENCE_THRESHOLD=0.72
REPRESENTATIVE_CONFIDENCE_THRESHOLD=0.68
MAX_HOLD_SECONDS=1800

